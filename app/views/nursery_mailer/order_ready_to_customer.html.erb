<h2 style="margin: 0 0 16px; font-size: 20px; color: #234766;">
  Votre commande est prête à être retirée
</h2>

<p>Bonjour <%= @order.customer_name %>,</p>

<p>
  Bonne nouvelle : votre commande <strong><%= @order.order_number %></strong>
  est <strong>prête</strong> et vous attend à la pépinière
  <strong><%= @nursery.name %></strong>.
</p>

<table style="width: 100%; margin: 24px 0; border-collapse: collapse; font-size: 14px;">
  <tr>
    <td style="padding: 6px 0; color: #666666; width: 160px;">Point de retrait</td>
    <td style="padding: 6px 0;">
      <strong><%= @nursery.name %></strong>
      <% if @nursery.address.present? || @nursery.city.present? %>
        <br>
        <span style="color: #555;">
          <%= [@nursery.address.presence, @nursery.postal_code.presence, @nursery.city.presence].compact.join(", ") %>
        </span>
      <% end %>
    </td>
  </tr>
  <% if @nursery.contact_phone.present? %>
  <tr>
    <td style="padding: 6px 0; color: #666666;">Téléphone</td>
    <td style="padding: 6px 0;"><%= @nursery.contact_phone %></td>
  </tr>
  <% end %>
  <tr>
    <td style="padding: 6px 0; color: #666666;">Total à régler</td>
    <td style="padding: 6px 0;"><strong><%= number_to_currency(@order.total_euros, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></strong> sur place</td>
  </tr>
</table>

<h3 style="font-size: 16px; color: #234766; margin: 24px 0 8px;">Votre commande</h3>
<table style="width: 100%; border-collapse: collapse; font-size: 13px; border: 1px solid #eaeaea;">
  <thead>
    <tr style="background-color: #f6f6f3;">
      <th style="text-align: left; padding: 8px; border-bottom: 1px solid #eaeaea;">Plante</th>
      <th style="text-align: left; padding: 8px; border-bottom: 1px solid #eaeaea;">Format</th>
      <th style="text-align: right; padding: 8px; border-bottom: 1px solid #eaeaea;">Qté</th>
    </tr>
  </thead>
  <tbody>
    <% @lines.each do |line| %>
      <tr>
        <td style="padding: 8px; border-bottom: 1px solid #f4f4f4;">
          <em><%= line.species_name %></em>
          <% if line.variety_name.present? %>
            <br><span style="color: #666; font-size: 12px;"><%= line.variety_name %></span>
          <% end %>
        </td>
        <td style="padding: 8px; border-bottom: 1px solid #f4f4f4;"><%= line.container_name %></td>
        <td style="padding: 8px; border-bottom: 1px solid #f4f4f4; text-align: right;"><%= line.quantity %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<p style="margin-top: 32px;">
  Pour organiser le retrait, contactez directement la pépinière. Si vous avez
  des questions, vous pouvez aussi répondre à cet email.
</p>

<p style="font-size: 13px; color: #666666;">
  Merci de soutenir nos pépinières-écoles.
</p>
