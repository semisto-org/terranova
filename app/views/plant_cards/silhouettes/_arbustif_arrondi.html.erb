<svg viewBox="0 0 240 <%= height_px %>" preserveAspectRatio="xMidYEnd meet">
  <% canopy_h = [height_px * 0.55, 90].min %>
  <% canopy_cy = canopy_h * 0.5 %>
  <ellipse cx="120" cy="<%= canopy_cy %>" rx="115" ry="<%= canopy_h * 0.45 %>" fill="var(--plant)" opacity=".88"/>
  <ellipse cx="75" cy="<%= canopy_cy + 20 %>" rx="55" ry="32" fill="var(--plant)" opacity=".75"/>
  <ellipse cx="170" cy="<%= canopy_cy + 15 %>" rx="55" ry="30" fill="var(--plant)" opacity=".75"/>
  <% trunk_top = canopy_h %>
  <rect x="116" y="<%= trunk_top %>" width="8" height="<%= [height_px - trunk_top, 0].max %>" fill="#5a4a36"/>
</svg>
