<svg viewBox="0 0 240 <%= height_px %>" preserveAspectRatio="xMidYEnd meet">
  <% trunk_h = [height_px * 0.15, 24].min %>
  <% canopy_h = height_px - trunk_h %>
  <ellipse cx="120" cy="<%= canopy_h * 0.5 %>" rx="80" ry="<%= canopy_h * 0.48 %>" fill="var(--plant)" opacity=".88"/>
  <ellipse cx="100" cy="<%= canopy_h * 0.7 %>" rx="55" ry="<%= canopy_h * 0.35 %>" fill="var(--plant)" opacity=".75"/>
  <rect x="116" y="<%= canopy_h %>" width="8" height="<%= trunk_h %>" fill="#5a4a36"/>
</svg>
