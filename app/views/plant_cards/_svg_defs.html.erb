    <symbol id="leaf-deciduous" viewBox="0 0 24 24">
      <path d="M12 2 C 4 4 2 11 5 17 C 8 22 12 22 12 22 C 12 22 16 22 19 17 C 22 11 20 4 12 2 Z"
