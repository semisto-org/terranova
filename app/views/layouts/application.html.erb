<!DOCTYPE html>
<html>
  <head>
    <title>Terranova</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <% if ENV['SENTRY_DSN'].present? %>
      <meta name="sentry-dsn" content="<%= ENV['SENTRY_DSN'] %>">
    <% end %>
    <meta name="theme-color" content="#5b5781">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <!-- bm-design-system:start -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <script>
      (function () {
        try {
          var stored = localStorage.getItem('bm-ds-theme');
          var theme = stored === 'light' || stored === 'dark' || stored === 'system' ? stored : 'system';
          var resolved = theme === 'system'
            ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
            : theme;
          if (resolved === 'dark') document.documentElement.classList.add('dark');
        } catch (e) {}
      })();
    </script>
    <!-- bm-design-system:end -->
    <%= vite_client_tag %>
    <%= vite_react_refresh_tag %>
    <%= vite_javascript_tag "application.jsx" %>
    <script async src="https://tally.so/widgets/embed.js"></script>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
